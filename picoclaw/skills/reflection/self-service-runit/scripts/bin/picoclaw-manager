#!/bin/bash
# picoclaw-manager - Generic service manager entry point
# Delegates to platform-specific handlers (picoclaw-service, picoclaw-config, etc.)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PLUGINS_DIR="${PICOCLAW_HOME:-$HOME/.picoclaw}/plugins"

# Validate identifier
assert_is_identifier() {
    if ! echo "$1" | grep -qE '^[a-zA-Z_][a-zA-Z0-9_-]*$'; then
        echo "Error: $2" >&2
        return 1
    fi
}

COMMAND="${1:-}"
[[ -z "$COMMAND" ]] && { echo "Usage: $0 <command> [args...]"; exit 1; }
assert_is_identifier "$COMMAND" "Invalid command" || exit 1

HANDLER="$PLUGINS_DIR/picoclaw-$COMMAND"

if [[ -x "$HANDLER" ]]; then
    shift
    exec "$HANDLER" "$@"
else
    echo "Error: Handler not found: $HANDLER" >&2
    exit 1
fi
